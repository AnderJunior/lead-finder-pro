# Supabase - Auth e banco de dados
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# Google Maps API Key - Necessário para mapas e busca de lugares (fallback)
# Obtenha em: https://console.cloud.google.com/google/maps-apis
# Habilite: Maps JavaScript API e Places API (New)
VITE_GOOGLE_MAPS_API_KEY=sua_chave_aqui

# Serper API Key - Busca de empresas com paginação real (recomendado)
# Obtenha em: https://serper.dev
VITE_SERPER_API_KEY=sua_chave_serper

# Evolution API WhatsApp - Validação de números (opcional)
VITE_WHATSAPP_BASE_URL=https://evolutionapi.seudominio.com.br
VITE_WHATSAPP_INSTANCE=nome_da_instancia
VITE_WHATSAPP_API_KEY=seu_token
VITE_WHATSAPP_AUTH_HEADER=apikey
