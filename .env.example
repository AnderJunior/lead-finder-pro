# Supabase - Auth e banco de dados
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Asaas - Gateway de pagamento (configurar nas Secrets do Supabase Edge Functions)
# No Supabase Dashboard > Project Settings > Edge Functions > Secrets, adicione:
#   ASAAS_API_KEY=sua_api_key_asaas
#   ASAAS_ENV=sandbox (ou production)
#   ASAAS_WEBHOOK_TOKEN=seu_token_seguro

# As chaves de API (Google Maps, Serper, Evolution API)
# são configuradas pelo admin em: Configurações > Integrações
